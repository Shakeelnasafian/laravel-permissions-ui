{
  "name": "shakeelnasafian/laravel-spatie-permission-manager",
  "description": "Elegant UI for managing spatie/laravel-permission roles and permissions",
  "version": "0.1.0",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.0|^11.0|^12.0",
    "spatie/laravel-permission": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "Shakeelnasafian\\PermissionManager\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Shakeelnasafian\\PermissionManager\\PermissionManagerServiceProvider"
      ]
    }
  }
}
